---
import { getDirectoryTree } from "@utils/directory";
import { widgetManager, getComponentConfig } from "@utils/widget";
import { i18n } from "@i18n/translation";
import I18nKey from "@i18n/i18nKey";
import WidgetLayout from "./widgetLayout.astro";
import DirectoryTree from "./directoryTree.svelte";


const directoryTree = await getDirectoryTree();

const COLLAPSED_HEIGHT = "12rem";

// 使用统一的组件管理器检查是否应该折叠
const directoryComponent = getComponentConfig("directory");
const countNodes = (nodes: any[]): number =>
    nodes.reduce((total, node) => total + 1 + (node.children ? countNodes(node.children) : 0), 0);
const totalDirectoryCount = countNodes(directoryTree);
const isCollapsed = directoryComponent ? widgetManager.isCollapsed(directoryComponent, totalDirectoryCount) : false;

interface Props {
    class?: string;
    style?: string;
    side?: string;
}
const { class: className, style, side = "default" } = Astro.props;

const currentPath = Astro.url.pathname;
---

<WidgetLayout
    name={i18n(I18nKey.directory)}
    id={`directory-${side}`}
    isCollapsed={isCollapsed}
    collapsedHeight={COLLAPSED_HEIGHT}
    class={className}
    style={style}
>
    <div class="directory-container">
        <DirectoryTree client:idle tree={directoryTree} currentPath={currentPath} />
    </div>
</WidgetLayout>

<script is:inline define:vars={{ side }}>
    const widgetId = `directory-${side}`;
    const ACTIVE_CLASSES = ["text-(--primary)", "bg-(--btn-plain-bg-hover)", "font-medium"];
    const INACTIVE_CLASS = "text-75";

    const normalizePath = (path) => {
        if (!path) return "";
        const normalized = path.replace(/\/$/, "");
        return normalized || "/";
    };

    const syncDirectoryHighlight = () => {
        const widget = document.getElementById(widgetId);
        if (!widget) return;

        const currentPath = normalizePath(window.location.pathname);
        const links = widget.querySelectorAll(".directory-container a[href]");

        links.forEach((link) => {
            const href = link.getAttribute("href");
            if (!href) return;

            const linkPath = normalizePath(new URL(href, window.location.origin).pathname);
            const isActive = currentPath === linkPath;

            ACTIVE_CLASSES.forEach((className) => link.classList.toggle(className, isActive));
            link.classList.toggle(INACTIVE_CLASS, !isActive);
        });
    };

    const registerDirectoryHighlightSync = () => {
        if (window.__directoryHighlightSyncRegistered?.[widgetId]) {
            syncDirectoryHighlight();
            return;
        }

        window.__directoryHighlightSyncRegistered = {
            ...(window.__directoryHighlightSyncRegistered || {}),
            [widgetId]: true,
        };

        if (window.swup?.hooks) {
            window.swup.hooks.on("page:view", syncDirectoryHighlight);
        }

        syncDirectoryHighlight();
    };

    registerDirectoryHighlightSync();

    if (!window.swup?.hooks) {
        document.addEventListener("swup:enable", registerDirectoryHighlightSync, { once: true });
    }
</script>
